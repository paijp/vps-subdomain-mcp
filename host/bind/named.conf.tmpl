// Authoritative-only BIND configuration for the VPS seminar DNS server.
// Installed as /etc/named.conf on dnf-based systems (RHEL/Rocky), where the
// stock named.conf is recursion-on and not suitable for an authoritative NS.
// Zone definitions live in the included named.conf.local.

options {
    listen-on port 53 { any; };
    listen-on-v6 port 53 { any; };
    directory       "/var/named";
    dump-file       "/var/named/data/cache_dump.db";
    statistics-file "/var/named/data/named_stats.txt";
    memstatistics-file "/var/named/data/named_mem_stats.txt";
    secroots-file   "/var/named/data/named.secroots";
    recursing-file  "/var/named/data/named.recursing";

    // Authoritative server: answer queries for our zones from anyone,
    // but do not provide recursion to the public.
    allow-query     { any; };
    recursion       no;
    dnssec-validation no;

    managed-keys-directory "/var/named/dynamic";
    pid-file        "/run/named/named.pid";
    session-keyfile "/run/named/session.key";

    include "/etc/crypto-policies/back-ends/bind.config";
};

logging {
    channel default_debug {
        file "data/named.run";
        severity dynamic;
    };
};

include "/etc/named.rfc1912.zones";
include "/etc/named.root.key";
include "/etc/named/named.conf.local";
