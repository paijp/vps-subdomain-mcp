# https://github.com/paijp/vps-subdomain-mcp

FROM debian:bookworm-slim

ENV DEBIAN_FRONTEND=noninteractive

# ── Base system ──────────────────────────────────────────────────────────────
RUN apt-get update && apt-get install -y --no-install-recommends \
    systemd systemd-sysv dbus \
    nginx certbot python3-certbot \
    openssl ca-certificates \
    postfix s-nail \
    curl gnupg \
    unattended-upgrades \
    && rm -rf /var/lib/apt/lists/*

# ── Node.js 20 (GPG-verified NodeSource repository) ──────────────────────────
RUN mkdir -p /etc/apt/keyrings \
    && curl -fsSL https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key \
       | gpg --dearmor -o /etc/apt/keyrings/nodesource.gpg \
    && echo "deb [signed-by=/etc/apt/keyrings/nodesource.gpg] https://deb.nodesource.com/node_20.x nodistro main" \
       > /etc/apt/sources.list.d/nodesource.list \
    && apt-get update \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/*

# ── Disable unwanted units ────────────────────────────────────────────────────
# apt-daily{,-upgrade}.timer are intentionally NOT masked: they drive
# unattended-upgrades so the long-lived container receives security updates.
RUN systemctl mask \
    getty@tty1.service \
    console-getty.service \
    systemd-logind.service \
    motd-news.timer \
    e2scrub_reap.service

# ── Automatic security updates ────────────────────────────────────────────────
# unattended-upgrades applies Debian security updates; the apt-daily timers
# (above) trigger it. The container itself never reboots — the host's weekly
# vps-mcp-reboot.timer plus --restart=always refreshes running containers.
RUN printf 'APT::Periodic::Update-Package-Lists "1";\nAPT::Periodic::Unattended-Upgrade "1";\n' \
        > /etc/apt/apt.conf.d/20auto-upgrades

# ── Self-signed certificate (replaced by certbot on first boot) ───────────────
RUN mkdir -p /etc/nginx/ssl \
    && openssl req -x509 -nodes -newkey rsa:2048 -days 3650 \
       -keyout /etc/nginx/ssl/privkey.pem \
       -out    /etc/nginx/ssl/fullchain.pem \
       -subj   "/CN=localhost"

# ── nginx configuration ───────────────────────────────────────────────────────
COPY nginx/vps-mcp.conf /etc/nginx/sites-available/vps-mcp.conf
RUN rm -f /etc/nginx/sites-enabled/default \
    && ln -s /etc/nginx/sites-available/vps-mcp.conf /etc/nginx/sites-enabled/vps-mcp.conf

# ── Postfix nullclient ────────────────────────────────────────────────────────
# myhostname is set by vps-mcp-init.sh at runtime.
RUN postconf -e \
    "relayhost = [10.89.0.1]:25" \
    "inet_interfaces = loopback-only" \
    "mydestination =" \
    "local_transport = error: local delivery disabled"

# ── MCP server ────────────────────────────────────────────────────────────────
RUN mkdir -p /opt/mcp
COPY mcp/package.json /opt/mcp/package.json
RUN cd /opt/mcp && npm install --omit=dev

COPY mcp/index.mjs /opt/mcp/index.mjs

# ── systemd units and scripts ─────────────────────────────────────────────────
# mcp-server.service is NOT enabled here; vps-mcp-init.sh calls
# "systemctl enable --now mcp-server" after writing /etc/vps-mcp-env.
COPY systemd/mcp-server.service    /etc/systemd/system/mcp-server.service
COPY systemd/vps-mcp-init.sh       /usr/local/bin/vps-mcp-init.sh
COPY systemd/certbot-deploy.sh     /usr/local/bin/certbot-deploy.sh

RUN chmod +x /usr/local/bin/vps-mcp-init.sh \
             /usr/local/bin/certbot-deploy.sh

RUN systemctl enable \
    nginx \
    postfix \
    certbot.timer \
    unattended-upgrades.service

# ── certbot deploy hook ───────────────────────────────────────────────────────
RUN mkdir -p /etc/letsencrypt/renewal-hooks/deploy \
    && ln -s /usr/local/bin/certbot-deploy.sh \
             /etc/letsencrypt/renewal-hooks/deploy/reload-nginx.sh

# ── Webroot directory for certbot --webroot ───────────────────────────────────
RUN mkdir -p /var/www/html/.well-known/acme-challenge

STOPSIGNAL SIGRTMIN+3
CMD ["/sbin/init"]
